# ── Required ──────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Change this to a long random string before deploying — never use the default
JWT_SECRET=change_this_secret

# ── AI Models ─────────────────────────────────────────────────────────────────
# Text agent — fast and cost-effective
OPENAI_MODEL=gpt-4o-mini

# Vision / OCR agent — used for schedule and plan image imports (costs more)
OPENAI_VISION_MODEL=gpt-5.4

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (no setup required). For MySQL use:
# mysql+pymysql://user:password@host/dbname
DATABASE_URL=sqlite+pysqlite:///./student_assistant.db

# ── App Settings ──────────────────────────────────────────────────────────────
APP_NAME=Student Assistant System

# JWT algorithm — HS256 is standard, do not change unless you know why
JWT_ALG=HS256

# Token expiry in minutes — 1440 = 24 hours
JWT_EXPIRE_MIN=1440

# Number of past messages to include as context in each AI request
CHAT_MEMORY_MESSAGES=20

# Set to false in production to hide /docs and /redoc Swagger UI
ENABLE_DOCS=true

# Allowed CORS origins. Use * for development only.
# In production, set to your actual domain: https://yourapp.example.com
CORS_ORIGINS=*
